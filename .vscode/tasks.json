				";",
				"git",
				"push",
				"origin",
				"main"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Push current branch",
			"type": "shell",
			"command": "git",
			"args": [
				"status",
				"--short",
				";",
				"git",
				"push",
				"origin",
				"main"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Push agenda reconnect section",
			"type": "shell",
			"command": "git",
			"args": [
				"add",
				"index.html",
				";",
				"git",
				"commit",
				"-m",
				"Add Outlook reconnect guide in Agenda",
				";",
